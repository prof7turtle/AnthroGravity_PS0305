# ── Node.js ───────────────────────────────────────────────────────────────────
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.npm

# ── TypeScript build output ───────────────────────────────────────────────────
dist/
build/
*.tsbuildinfo

# ── Environment — NEVER commit secrets ───────────────────────────────────────
.env
.env.local
.env.*.local

# ── AlgoKit / Algorand compiled output ────────────────────────────────────────
# TEAL + ARC-32 artifacts are re-generated by `algokit project run build`
artifacts/
*.teal
*.arc32.json
*.arc56.json

# ── Python legacy stubs (from original template) ──────────────────────────────
__pycache__/
*.py[cod]
*.pyo
.venv/
venv/

# ── Test & Coverage ───────────────────────────────────────────────────────────
coverage/
*.lcov
.nyc_output/

# ── Logs ──────────────────────────────────────────────────────────────────────
logs/
*.log

# ── OS ────────────────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db

# ── Editor ────────────────────────────────────────────────────────────────────
.idea/
*.suo
*.sw?
