{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "strict": true,
    "outDir": "dist",
    "rootDir": ".",
    "skipLibCheck": true,
    "allowImportingTsExtensions": false,
    "paths": {
      "@algorandfoundation/algorand-typescript": [
        "./node_modules/@algorandfoundation/algorand-typescript/index.d.ts"
      ]
    }
  },
  "include": ["src/**/*.ts", "tests/**/*.ts"],
  "exclude": ["node_modules", "dist"]
}
