{
  "name": "algoescrow-contracts",
  "version": "1.0.0",
  "description": "AlgoEscrow Smart Contracts — Algorand TypeScript (PuyaTs)",
  "private": true,
  "scripts": {
    "build": "npx puya-ts src/*.algo.ts --out-dir src/artifacts",
    "generate-clients": "algokit generate client src/artifacts/EscrowFactory.arc32.json --output src/contracts/EscrowFactoryClient.ts && algokit generate client src/artifacts/EscrowContract.arc32.json --output src/contracts/EscrowContractClient.ts",
    "deploy": "npx ts-node --transpileOnly src/deploy.ts",
    "deploy:testnet": "cross-env ALGORAND_NETWORK=testnet npx ts-node --transpileOnly src/deploy.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "compile": "npx puya-ts src/*.algo.ts --out-dir src/artifacts"
  },
  "dependencies": {
    "@algorandfoundation/algorand-typescript": "^1.1.0"
  },
  "devDependencies": {
    "@algorandfoundation/algokit-utils": "^7.0.0",
    "@algorandfoundation/algorand-typescript-testing": "^1.1.0",
    "@algorandfoundation/puya-ts": "^1.1.0",
    "algosdk": "^3.0.0",
    "cross-env": "^7.0.3",
    "dotenv": "^16.0.0",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
}
