# AlgoEscrow — Smart Contract Environment
# Copy to .env and fill in values

# ── Algorand Network ──────────────────────────────────────────────────────────
ALGORAND_NETWORK=localnet

# ── LocalNet (default AlgoKit values) ────────────────────────────────────────
ALGORAND_ALGOD_URL=http://localhost:4001
ALGORAND_ALGOD_TOKEN=aaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaa
ALGORAND_INDEXER_URL=http://localhost:8980
ALGORAND_KMD_URL=http://localhost:4002

# ── Testnet (AlgoNode public endpoints) ──────────────────────────────────────
# ALGORAND_NETWORK=testnet
# ALGORAND_ALGOD_URL=https://testnet-api.algonode.cloud
# ALGORAND_ALGOD_TOKEN=
# ALGORAND_INDEXER_URL=https://testnet-idx.algonode.cloud

# ── Deployer wallet ───────────────────────────────────────────────────────────
# For localnet: leave empty (uses KMD unencrypted-default-wallet)
# For testnet: set your 25-word mnemonic
DEPLOYER_MNEMONIC=

# ── Platform Config ───────────────────────────────────────────────────────────
# Platform treasury address (receives 0.5% fees)
PLATFORM_TREASURY_ADDRESS=

# Arbiter address (resolves disputes)
ARBITER_ADDRESS=

# Platform fee in basis points (50 = 0.5%)
PLATFORM_FEE_BPS=50
