# ── Node.js ───────────────────────────────────────────────────────────────────
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
.npm

# ── TypeScript build output ───────────────────────────────────────────────────
dist/
build/
*.tsbuildinfo

# ── Environment — NEVER commit secrets ───────────────────────────────────────
# API keys, mnemonics, and private keys must NEVER be committed
.env
.env.local
.env.*.local
.env.production
.env.staging

# ── Logs ──────────────────────────────────────────────────────────────────────
logs/
*.log
pids/
*.pid
*.seed

# ── Auto-generated contract clients ───────────────────────────────────────────
# These are copied from smart-contract/artifacts after build
src/contracts/*.ts
!src/contracts/.gitkeep

# ── Test & Coverage ───────────────────────────────────────────────────────────
coverage/
*.lcov
.nyc_output/

# ── OS ────────────────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db

# ── Editor ────────────────────────────────────────────────────────────────────
.idea/
*.suo
*.sw?
