# Server Configuration
PORT=5000
NODE_ENV=development

# MongoDB
MONGO_URI=mongodb://127.0.0.1:27017/algoescrow

# JWT
JWT_SECRET=your-super-secret-jwt-key-change-in-production

# Algorand Network Configuration
ALGORAND_NETWORK=localnet
ALGORAND_ALGOD_URL=http://localhost:4001
ALGORAND_ALGOD_TOKEN=aaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaa
ALGORAND_INDEXER_URL=http://localhost:8980

# For TestNet, use:
# ALGORAND_NETWORK=testnet
# ALGORAND_ALGOD_URL=https://testnet-api.algonode.cloud
# ALGORAND_ALGOD_TOKEN=
# ALGORAND_INDEXER_URL=https://testnet-idx.algonode.cloud

# Deployed Contract App IDs (from smart-contract/.env after deployment)
ESCROW_CONTRACT_TEMPLATE_APP_ID=1197
ESCROW_FACTORY_APP_ID=1198

# Platform Configuration
PLATFORM_TREASURY_ADDRESS=CE2OO7ENA7O5STYUFUTENFPPSLWBWL3NVKVIKFRCX3BYYSWKH753HJ5GV4
ARBITER_ADDRESS=CE2OO7ENA7O5STYUFUTENFPPSLWBWL3NVKVIKFRCX3BYYSWKH753HJ5GV4
PLATFORM_FEE_BPS=50

# Escrow custody wallet used for backend-signed on-chain actions (refund/arbitration)
# For localnet: leave empty (will use KMD)
# For testnet/mainnet: set the 25-word mnemonic of the custody account
ESCROW_MNEMONIC=

# Legacy alias (optional): kept for backward compatibility
ORACLE_MNEMONIC=

# AI Service (Claude API for Freelance escrow verification)
CLAUDE_API_KEY=your-claude-api-key-here
CLAUDE_MODEL=claude-3-5-sonnet-20241022

# CORS
CORS_ORIGIN=http://localhost:5173
